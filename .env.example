# Local Development
# DATABASE_URL is set to SQLite for local development
DATABASE_URL="file:./prisma/dev.db"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"
JWT_EXPIRY=24

# Admin Credentials (change immediately in production)
ADMIN_EMAIL="admin@rditlab.co.uk"
ADMIN_PASSWORD="ChangeMe123!"

# API URL
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Email Notifications (Optional - leave blank to skip email alerts)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="no-reply@rditlab.co.uk"
ALERT_EMAIL="admin@rditlab.co.uk"

# Production Configuration (for Vercel/Cloud Deployment)
# Set these in your Vercel environment variables:
# DATABASE_URL="postgresql://user:password@host:5432/rditlab"
# JWT_SECRET="generate-a-new-32-character-random-secret"
# NEXT_PUBLIC_API_URL="https://yourdomain.com"
# EMAIL env vars as above
